
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // Admin Roles
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    // Bookings (Matches the 'bookings' collection used in the app)
    match /bookings/{bookingId} {
      allow create: if isSignedIn();
      // Allow list for any signed-in user for now to unblock Admin panel, 
      // but ideally this should be restricted to admins in production.
      allow list, get: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.clientId || isAdmin());
    }

    // Appointments (Legacy support for old collection name if any)
    match /appointments/{appointmentId} {
      allow create: if isSignedIn();
      allow list, get: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.clientId || isAdmin());
    }

    // User Profiles
    match /users/{userId}/profile {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    // Barbers
    match /barbers/{barberId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || isOwner(barberId);
    }

    // Services
    match /services/{serviceId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
