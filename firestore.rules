
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isGlobalAdmin();
      allow list: if isGlobalAdmin();
      allow create, update, delete: if false; 
    }

    match /clients/{clientId} {
      allow read, create: if isGlobalAdmin();
      allow update, delete: if isGlobalAdmin();
    }

    match /barbers/{barberId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();
    }

    match /barbers/{barberId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if true; // Публичные отзывы
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isGlobalAdmin();
      allow create: if true; 
      allow update, delete: if isGlobalAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }
  }
}
