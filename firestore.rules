rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BARBERSHOP CRM & BOOKING SYSTEM SECURITY RULES
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isAnyBarber() {
      return isSignedIn() && exists(/databases/$(database)/documents/barbers/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Коллекция администраторов. 
     * Разрешаем любому вошедшему пользователю проверить СВОЙ статус (get), 
     * чтобы страница входа могла понять, пускать его или нет.
     */
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isGlobalAdmin();
      allow list: if isGlobalAdmin();
      allow create, update, delete: if false; 
    }

    match /clients/{clientId} {
      allow get: if isOwner(clientId) || isAnyBarber() || isGlobalAdmin();
      allow list: if isGlobalAdmin() || isAnyBarber();
      allow create: if isOwner(clientId);
      allow update: if (isOwner(clientId) || isGlobalAdmin()) && (request.resource.data.id == clientId);
      allow delete: if isGlobalAdmin();
    }

    match /barbers/{barberId} {
      allow get, list: if true;
      allow create: if isGlobalAdmin();
      allow update: if (isOwner(barberId) || isGlobalAdmin()) && (request.resource.data.id == barberId);
      allow delete: if isGlobalAdmin();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();
    }

    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || isGlobalAdmin());
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && (request.resource.data.clientId == request.auth.uid || isGlobalAdmin());
      allow update: if resource != null && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || isGlobalAdmin()) && (request.resource.data.clientId == resource.data.clientId);
      allow delete: if isGlobalAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isGlobalAdmin();
      allow create: if true; // Публичное бронирование
      allow update, delete: if isGlobalAdmin();
    }

    match /barbers/{barberId}/availabilities/{availabilityId} {
      allow get, list: if true;
      allow create: if (isOwner(barberId) || isGlobalAdmin());
      allow update, delete: if resource != null && (isOwner(barberId) || isGlobalAdmin());
    }

    match /users/{userId}/hairstyleVisualizations/{visualizationId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }
  }
}