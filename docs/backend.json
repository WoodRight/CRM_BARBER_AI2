
{
  "entities": {
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" }
      }
    },
    "Barber": {
      "title": "Barber",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Топ-барбер", "Мастер", "Барбер"] },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" }
      }
    },
    "Review": {
      "title": "Review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "barberId": { "type": "string" },
        "clientName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/roles_admin/{adminId}": {
      "schema": "object",
      "description": "Admin roles for dashboard access."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/backend/entities/Booking" },
      "description": "Public and admin managed appointments."
    },
    "/services/{serviceId}": {
      "schema": "object",
      "description": "Barbershop services."
    },
    "/barbers/{barberId}": {
      "schema": { "$ref": "#/backend/entities/Barber" },
      "description": "Barber profiles."
    },
    "/barbers/{barberId}/reviews/{reviewId}": {
      "schema": { "$ref": "#/backend/entities/Review" },
      "description": "Reviews for a specific barber."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Client database."
    }
  }
}
