
{
  "entities": {
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" }
      }
    },
    "Barber": {
      "title": "Barber",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/roles_admin/{adminId}": {
      "schema": "object",
      "description": "Admin roles for dashboard access."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/backend/entities/Booking" },
      "description": "Public and admin managed appointments."
    },
    "/services/{serviceId}": {
      "schema": "object",
      "description": "Barbershop services."
    },
    "/barbers/{barberId}": {
      "schema": { "$ref": "#/backend/entities/Barber" },
      "description": "Barber profiles."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Client database."
    }
  }
}
