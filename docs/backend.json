{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Запись клиента на услугу в барбершоп.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string", "description": "Имя клиента" },
        "serviceName": { "type": "string", "description": "Название выбранной услуги" },
        "barberName": { "type": "string", "description": "Имя выбранного мастера" },
        "date": { "type": "string", "format": "date", "description": "Дата визита" },
        "time": { "type": "string", "description": "Время визита" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled", "completed"], "description": "Статус записи" },
        "totalPrice": { "type": "number", "description": "Стоимость услуги" },
        "aiResultUrl": { "type": "string", "format": "uri", "description": "Ссылка на результат ИИ-примерки" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Время создания записи" }
      },
      "required": ["clientName", "serviceName", "barberName", "date", "time", "status", "totalPrice", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Коллекция всех записей в барбершоп."
    },
    "/roles_owner/{userId}": {
      "schema": { "type": "object", "properties": { "isActive": { "type": "boolean" } } },
      "description": "Роли администраторов системы."
    }
  }
}